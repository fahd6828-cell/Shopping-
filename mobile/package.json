{
  "name": "souqly-mobile",
  "version": "0.1.0",
  "description": "Souqly — Arabic-first shopping assistant mobile app (React Native)",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "typecheck": "tsc --noEmit",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output build/index.android.bundle --assets-dest build/res"
  },
  "dependencies": {
    "@react-native-clipboard/clipboard": "^1.14.1",
    "react": "18.3.1",
    "react-native": "0.75.4",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "react-native-safe-area-context": "^4.11.0",
    "react-native-screens": "^3.34.0",
    "react-native-svg": "^15.7.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.6.0",
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "0.75.4",
    "@react-native/metro-config": "0.75.4",
    "@react-native-community/cli": "14.1.0",
    "@react-native-community/cli-platform-android": "14.1.0",
    "@react-native-community/cli-platform-ios": "14.1.0"
  }
}