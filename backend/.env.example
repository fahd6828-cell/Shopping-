# Server
PORT=3000

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgres://souqly:souqly_dev@localhost:5432/souqly

# Redis
REDIS_URL=redis://localhost:6379

# Price cache TTL in seconds (3 hours per product spec)
SEARCH_CACHE_TTL_SECONDS=10800

# Per-store-adapter timeout in milliseconds
ADAPTER_TIMEOUT_MS=8000

# "inline" (dev: adapters run inside the API process) or "queue"
# (production: BullMQ worker process consumes scrape jobs — run `npm run worker`)
QUEUE_MODE=inline
# How long /api/search waits for in-flight scrape jobs (queue mode)
SCRAPE_WAIT_MS=4000
# DB listings younger than this serve searches without a re-scrape (3h)
LISTING_FRESHNESS_MS=10800000

# Real Playwright scraping in the worker; "false" = realistic mocks
SCRAPER_ENABLED=false
CHROMIUM_PATH=

# Amazon PA-API 5 (leave empty to use the mock adapter)
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=

# Firebase service account JSON (single line) for FCM pushes; empty = dry-run
FIREBASE_SERVICE_ACCOUNT_JSON=
